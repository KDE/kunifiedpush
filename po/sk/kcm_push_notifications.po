#: ui/main.qml:28
#, kde-format
msgid "There is no push notification service running!"
msgstr "Nie je spustená žiadna služba push notifikácií!"

#: ui/main.qml:37
#, kde-format
msgid ""
"There is a 3rd party push notification service running. Push notifications "
"are available, but cannot be configured here."
msgstr ""
"Je spustená služba push notifikácií tretej strany. Push notifikácie sú "
"dostupné, ale nie je možné ich tu nastaviť."

#: ui/main.qml:46
#, kde-format
msgid ""
"<b>Online</b><br>Connected to the push notification server and operational."
msgstr "<b>Online</b><br>Pripojené k serveru push notifikácií a funkčné."

#: ui/main.qml:55
#, kde-format
msgid "<b>Idle</b><br>There are no applications using push notifications."
msgstr "<b>Nečinné</b><br>Žiadne aplikácie nepoužívajú push notifikácie."

#: ui/main.qml:65
#, kde-format
msgid ""
